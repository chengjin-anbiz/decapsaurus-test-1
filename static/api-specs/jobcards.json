    "/api/ServiceJob/{serviceId}/tasks/{taskId}": {
      "put": {
        "tags": [
          "ServiceJob"
        ],
        "description": "Update Task Information by Service Engineer. It includes upload documents.\r\n\r\nExample:\r\n    PUT api/servicejob/5/file.pdf/signature",
        "operationId": "UpdateTaskWithTaskId",
        "parameters": [
          {
            "name": "serviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 117
            }
          },
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 157
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "RepairDurationHour": {
                    "type": "integer",
                    "format": "int32",
                    "default": 4
                  },
                  "RepairDurationMinute": {
                    "type": "integer",
                    "format": "int32",
                    "default": 30
                  },
                  "AssignedEngineerUserId": {
                    "type": "string",
                    "default": "snk_sandbox"
                  },
                  "ServiceTypeId": {
                    "type": "integer",
                    "format": "int32",
                    "default": 18
                  },
                  "TaskDescription": {
                    "type": "string",
                    "default": "Task Description Test 1"
                  },
                  "TaskRemark": {
                    "type": "string",
                    "default": "Task Remark Test 1"
                  },
                  "TaskStatusId": {
                    "type": "integer",
                    "format": "int32",
                    "default": 67
                  },
                  "TaskDocs": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              },
              "encoding": {
                "RepairDurationHour": {
                  "style": "form"
                },
                "RepairDurationMinute": {
                  "style": "form"
                },
                "AssignedEngineerUserId": {
                  "style": "form"
                },
                "ServiceTypeId": {
                  "style": "form"
                },
                "TaskDescription": {
                  "style": "form"
                },
                "TaskRemark": {
                  "style": "form"
                },
                "TaskStatusId": {
                  "style": "form"
                },
                "TaskDocs": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
